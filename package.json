{
    "name":  "vibe-coding-always-on",
    "version":  "1.3.4",
    "description":  "Minimal Windows tray utility for always-on coding and agent sessions.",
    "license":  "MIT",
    "bin":  {
                "vibe-coding-always-on":  "npm/bin/vibe-coding-always-on.js",
                "vcao":  "npm/bin/vibe-coding-always-on.js"
            },
    "files":  [
                  "dist/VibeCodingAlwaysOnTray.exe",
                  "install.ps1",
                  "npm/bin/vibe-coding-always-on.js",
                  "README.md",
                  "README.zh-CN.md",
                  "RELEASE_NOTES.md",
                  "SECURITY.md",
                  "LICENSE"
              ],
    "scripts":  {
                    "build":  "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build.ps1",
                    "package:win":  "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package.ps1",
                    "release":  "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/release.ps1 -NpmPack",
                    "prepare":  "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build.ps1",
                    "selftest":  "node npm/bin/vibe-coding-always-on.js selftest --bundled"
                },
    "keywords":  [
                     "windows",
                     "tray",
                     "powercfg",
                     "sleep",
                     "codex",
                     "claude-code",
                     "agent"
                 ],
    "os":  [
               "win32"
           ],
    "engines":  {
                    "node":  "\u003e=16"
                },
    "repository":  {
                       "type":  "git",
                       "url":  "git+https://github.com/KujalaLucien/vibe-coding-always-on.git"
                   },
    "homepage":  "https://github.com/KujalaLucien/vibe-coding-always-on#readme",
    "bugs":  {
                 "url":  "https://github.com/KujalaLucien/vibe-coding-always-on/issues"
             }
}
